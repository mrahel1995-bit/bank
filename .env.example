# ══════════════════════════════════════
#  النظام المالي الموحد — إعدادات البيئة
#  انسخ هذا الملف إلى .env وعدّل القيم
# ══════════════════════════════════════

# رابط قاعدة البيانات PostgreSQL
# من Render: ستجده في لوحة تحكم قاعدة البيانات
DATABASE_URL=postgresql://user:password@host:5432/dbname

# البيئة
NODE_ENV=production

# المنفذ (Render يضبطه تلقائياً)
PORT=3000
